5:["$","li",null,{"children":"AI is treated as an instrument of insight, not an arbiter of truth."}]
6:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"2. Data Usage Philosophy"}]
7:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Data used or referenced in AI-assisted contexts is handled in accordance with the following principles:"}]
8:["$","ul",null,{"className":"PrivacyPolicy_list__2UMD_","children":[["$","li",null,{"children":"Purpose Limitation: Data is used only for clearly defined analytical, educational, or operational purposes"}],["$","li",null,{"children":"Data Minimization: Only data reasonably necessary for the stated purpose is used"}],["$","li",null,{"children":"Context Preservation: Data is interpreted within its appropriate historical, organizational, and analytical context"}],["$","li",null,{"children":"Human Oversight: All meaningful interpretation remains subject to human review"}]]}]
9:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Metaratus® does not use AI to infer intent, morality, or individual character."}]
a:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"3. Types of Data Involved"}]
b:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Depending on the context, AI-assisted analysis may involve:"}]
c:["$","ul",null,{"className":"PrivacyPolicy_list__2UMD_","children":[["$","li",null,{"children":"Publicly available information"}],["$","li",null,{"children":"High-level operational or conceptual data"}],["$","li",null,{"children":"Aggregated or anonymized datasets"}],["$","li",null,{"children":"Hypothetical or illustrative examples"}]]}]
d:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Metaratus® does not knowingly process sensitive personal data for AI-driven decision-making purposes through the Website."}]
e:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"4. AI Limitations and Non-Reliance"}]
f:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Artificial intelligence systems are inherently limited. Accordingly:"}]
10:["$","ul",null,{"className":"PrivacyPolicy_list__2UMD_","children":[["$","li",null,{"children":"AI-generated outputs may be incomplete, inaccurate, or contextually misaligned"}],["$","li",null,{"children":"Outputs are not guarantees, predictions, or recommendations"}],["$","li",null,{"children":"AI does not possess understanding, intent, or awareness"}]]}]
11:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Users must not rely on AI-assisted materials as a substitute for independent judgment, professional advice, or due diligence."}]
12:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"5. No Autonomous or High-Risk AI Use"}]
13:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Metaratus® does not deploy or endorse:"}]
14:["$","ul",null,{"className":"PrivacyPolicy_list__2UMD_","children":[["$","li",null,{"children":"Fully autonomous decision-making systems"}],["$","li",null,{"children":"AI systems that operate without human oversight"}],["$","li",null,{"children":"AI used for behavioral manipulation, surveillance, or profiling"}],["$","li",null,{"children":"AI systems intended to replace human ethical judgment"}]]}]
15:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Where AI is used, it is constrained by design and governance."}]
16:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"6. Model Training and User Data"}]
17:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Metaratus® does not use personal data collected through the Website to train proprietary or third-party AI models unless expressly disclosed and lawfully permitted."}]
18:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Where third-party AI tools or platforms are referenced, their data handling practices are governed by their respective policies."}]
19:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"7. Bias Awareness and Risk Mitigation"}]
1a:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Metaratus® acknowledges that AI systems may reflect biases present in data or underlying models. To mitigate this risk:"}]
1b:["$","ul",null,{"className":"PrivacyPolicy_list__2UMD_","children":[["$","li",null,{"children":"AI outputs are treated as provisional, not authoritative"}],["$","li",null,{"children":"Human review is required for interpretation and application"}],["$","li",null,{"children":"Analytical methods emphasize structure, causality, and constraint over pattern-only inference"}]]}]
1c:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Prisma™ exists, in part, to guard against reductive or misleading conclusions."}]
1d:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"8. Security and Integrity"}]
1e:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Reasonable safeguards are applied to protect data integrity and prevent unauthorized access. However, no system is entirely immune to risk. Users acknowledge that AI-assisted environments involve inherent technical and informational limitations."}]
1f:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"9. Regulatory and Ethical Alignment"}]
20:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Metaratus® designs its AI posture to be consistent with:"}]
21:["$","ul",null,{"className":"PrivacyPolicy_list__2UMD_","children":[["$","li",null,{"children":"Emerging AI governance principles"}],["$","li",null,{"children":"Data protection regulations (including GDPR and CCPA/CPRA)"}],["$","li",null,{"children":"Institutional expectations around accountability and transparency"}]]}]
22:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"This Statement may evolve as regulatory frameworks and best practices mature."}]
23:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"10. No Waiver of Human Accountability"}]
24:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Nothing in this Statement, nor any AI-assisted material, shall be construed as transferring responsibility from human actors to automated systems."}]
25:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Decisions informed by AI remain human decisions, with all attendant responsibilities."}]
26:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"11. Changes to This Statement"}]
27:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":"Metaratus® reserves the right to update this Statement at any time. Updates will be effective upon posting. Continued use of the Website constitutes acceptance of the revised Statement."}]
28:["$","h2",null,{"className":"PrivacyPolicy_heading2__oAC_s","children":"12. Contact Information"}]
29:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","children":["For questions regarding data usage or AI safety practices, please contact:",["$","br",null,{}],["$","strong",null,{"children":"Metaratus®"}],["$","br",null,{}],"📧 ",["$","a",null,{"href":"mailto:info@metaratus.ai","className":"PrivacyPolicy_link__Pm6ww","children":"info@metaratus.ai"}],["$","br",null,{}],"🌐 ",["$","a",null,{"href":"https://metaratus.ai","className":"PrivacyPolicy_link__Pm6ww","children":"https://metaratus.ai"}]]}]
2a:["$","p",null,{"className":"PrivacyPolicy_paragraph__goKtZ","style":{"marginTop":"3rem","fontStyle":"italic","borderTop":"1px solid rgba(255,255,255,0.1)","paddingTop":"1.5rem"},"children":"Metaratus® maintains that intelligence without judgment is not wisdom, and automation without responsibility is not progress. This Statement exists to ensure that analytical power advances human understanding rather than obscuring it."}]
