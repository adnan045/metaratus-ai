"li",null,{"children":"AI is used to augment human analysis, not replace human judgment"}],["$","li",null,{"children":"Responsibility, accountability, and decision authority remain with humans"}],["$","li",null,{"children":"No AI system operated or referenced by Metaratus® is permitted to act as a final decision-maker in matters that carry legal, ethical, financial, or strategic consequence"}],"$L5"]}],"$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a"]}]]}]}],"$L2b"],["$L2c"],"$L2d"]}],{},null,false]},null,false]},null,false],"$L2e",false]],"m":"$undefined","G":["$2f",[]],"s":false,"S":true}
