:[null,["$","$L2",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["hybrid-intelligence",["$","$1","c",{"children":[null,["$","$L2",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","$L4",null,{}],["$","main",null,{"className":"ArticleLayout_container__0flR8","children":[["$","$L5",null,{"href":"/#reviews","className":"ArticleLayout_backButton__0ufGM","children":"← Back to Insights"}],["$","header",null,{"className":"ArticleLayout_hero__AN1ze","children":[["$","h1",null,{"className":"ArticleLayout_title__As5Gt","children":"Humanocentric™ AI: Hybrid Intelligence™ Within the Metaratus® Framework"}],["$","p",null,{"className":"ArticleLayout_subtitle__3FPit","children":"Humanocentric™ AI as the Metaratus® Governing Framework"}],["$","div",null,{"className":"ArticleLayout_meta___kLVp","children":[["$","div",null,{"className":"ArticleLayout_author__XLgy7","children":[["$","div",null,{"className":"ArticleLayout_authorAvatar__w_wz_","children":["$","svg",null,{"width":"18","height":"18","viewBox":"0 0 24 24","fill":"none","stroke":"white","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","path",null,{"d":"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"}],["$","circle",null,{"cx":"12","cy":"7","r":"4"}]]}]}],["$","span",null,{"children":"Metaratus® Research"}]]}],["$","span",null,{"className":"ArticleLayout_dot__nQzTA","children":"•"}],["$","span",null,{"children":"March 2026"}],["$","span",null,{"className":"ArticleLayout_dot__nQzTA","children":"•"}],["$","span",null,{"children":"7 min read"}]]}]]}],["$","article",null,{"className":"ArticleLayout_content___Im_T","children":[["$","p",null,{"children":"Just as life must be experience through the intangible qualities that make us uniquely human, as opposed to automatons, at Metaratus®, Humanocentric™ AI is the governing framework through which artificial intelligence is understood, designed, and applied to real-world human problems. We staunchly maintain that AI exists solely to extend human cognition, not replace it, and that accountability, judgment, and strategic intent must remain human-centered in order for AI to serve a utility maximizing role in society. Within this framework, Hybrid Intelligence™ represents a core operating principle for decision-making."}],"$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14"]}]]}],"$L15"],["$L16","$L17"],"$L18"]}],{},null,false]},null,false]},null,false]},null,false],"$L19",false]],"m":"$undefined","G":["$1a",[]],"s":false,"S":true}
