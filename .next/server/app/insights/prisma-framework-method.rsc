hildren":[null,["$","$L2",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["prisma-framework-method",["$","$1","c",{"children":[null,["$","$L2",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","$L4",null,{}],["$","main",null,{"className":"ArticleLayout_container__0flR8","children":[["$","$L5",null,{"href":"/#reviews","className":"ArticleLayout_backButton__0ufGM","children":"← Back to Insights"}],["$","header",null,{"className":"ArticleLayout_hero__AN1ze","children":[["$","h1",null,{"className":"ArticleLayout_title__As5Gt","children":"The Prisma™ Framework: Behind the Method"}],["$","p",null,{"className":"ArticleLayout_subtitle__3FPit","children":"A deeper look at the Metaratus® approach to clarity, structure, and strategic insight."}],["$","div",null,{"className":"ArticleLayout_meta___kLVp","children":[["$","div",null,{"className":"ArticleLayout_author__XLgy7","children":[["$","div",null,{"className":"ArticleLayout_authorAvatar__w_wz_","children":["$","svg",null,{"width":"18","height":"18","viewBox":"0 0 24 24","fill":"none","stroke":"white","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","path",null,{"d":"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"}],["$","circle",null,{"cx":"12","cy":"7","r":"4"}]]}]}],["$","span",null,{"children":"Ann Miller"}]]}],["$","span",null,{"className":"ArticleLayout_dot__nQzTA","children":"•"}],["$","span",null,{"children":"24 AUG, 2024"}],["$","span",null,{"className":"ArticleLayout_dot__nQzTA","children":"•"}],["$","span",null,{"children":"12 min read"}]]}]]}],["$","article",null,{"className":"ArticleLayout_content___Im_T","children":[["$","h2",null,{"children":"1. The Challenge of Strategic Clarity in Complex Systems"}],["$","p",null,{"children":"Unlike in the eras of the First and Second Industrial Revolutions, when innovations such as steam power, hand tools, electricity, and internal combustion engines were collectively created, modern organizations are not constrained by a lack of information; they are constrained by an overabundance of it, in the sense that with such a plethora of data streams, dashboards, metrics, models, and signals available at the click of a button, information accumulates faster than it can be meaningfully interpreted. As a result of this information backlog, decision-makers are often forced into reactive behavior—responding to surface indicators that only tell half the story, rather than understanding the deeper, subterranean structures and variables that drive business outcomes."}],"$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c"]}]]}],"$L2d"],["$L2e","$L2f"],"$L30"]}],{},null,false]},null,false]},null,false]},null,false],"$L31",false]],"m":"$undefined","G":["$32",[]],"s":false,"S":true}
39:I[8213,["481","static/chunks/481-626fdb7934d68317.js","535","static/chunks/535-e719f04704a6c057.js","856","static/chunks/app/insights/prisma-framework-method/page-60636936101b6d6c.js"],"default"]
