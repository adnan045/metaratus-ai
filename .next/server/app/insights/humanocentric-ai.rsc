,["$","$L2",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["humanocentric-ai",["$","$1","c",{"children":[null,["$","$L2",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","$L4",null,{}],["$","main",null,{"className":"ArticleLayout_container__0flR8","children":[["$","$L5",null,{"href":"/#reviews","className":"ArticleLayout_backButton__0ufGM","children":"← Back to Insights"}],["$","header",null,{"className":"ArticleLayout_hero__AN1ze","children":[["$","h1",null,{"className":"ArticleLayout_title__As5Gt","children":"Humanocentric™ AI: The Next Evolution of Work"}],["$","p",null,{"className":"ArticleLayout_subtitle__3FPit","children":"A Human-First Perspective on Artificial Intelligence"}],["$","div",null,{"className":"ArticleLayout_meta___kLVp","children":[["$","div",null,{"className":"ArticleLayout_author__XLgy7","children":[["$","div",null,{"className":"ArticleLayout_authorAvatar__w_wz_","children":["$","svg",null,{"width":"18","height":"18","viewBox":"0 0 24 24","fill":"none","stroke":"white","strokeWidth":"2","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","path",null,{"d":"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"}],["$","circle",null,{"cx":"12","cy":"7","r":"4"}]]}]}],["$","span",null,{"children":"Metaratus® Research"}]]}],["$","span",null,{"className":"ArticleLayout_dot__nQzTA","children":"•"}],["$","span",null,{"children":"March 2026"}],["$","span",null,{"className":"ArticleLayout_dot__nQzTA","children":"•"}],["$","span",null,{"children":"6 min read"}]]}]]}],["$","article",null,{"className":"ArticleLayout_content___Im_T","children":[["$","p",null,{"children":"At Metaratus®, we approach artificial intelligence not as a substitute for human intellect, but as a force to multiply it. We have observed that much of the prevailing discourse around AI has framed the technology as competitive—machines versus humans, automation versus labor, efficiency versus judgment. In our view, this framing is incomplete and increasingly misaligned with the realities of modern work. For this reason, we have developed the Humanocentric™ AI framework that aims to leverage AI as an engine of human advancement."}],["$","h3",null,{"children":"Defining Humanocentric™ AI"}],"$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11"]}]]}],"$L12"],["$L13","$L14"],"$L15"]}],{},null,false]},null,false]},null,false]},null,false],"$L16",false]],"m":"$undefined","G":["$17",[]],"s":false,"S":true}
